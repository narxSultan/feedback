PORT=5001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/feedback_system
FRONTEND_BASE_URL=http://localhost:4200

# Upload limits
UPLOAD_IMAGE_MAX_MB=1.5
EVENT_IMAGE_MAX_MB=1.5
PROFILE_IMAGE_MAX_MB=1.0

# Email setup for forgot-password / reset-password
# Option 1: Gmail with App Password
# EMAIL_PROVIDER=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-16-char-app-password

# Option 2: Custom SMTP
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password

# Optional sender name/email shown in the email
# FROM_EMAIL="Feedback System <no-reply@yourdomain.com>"
